    "@octokit/rest": "^22.0.0",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "openai": "^5.20.0",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
