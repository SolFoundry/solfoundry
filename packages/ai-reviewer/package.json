{
  "name": "solfoundry-ai-review",
  "version": "1.0.0",
  "description": "GitHub App for multi-LLM automated pull request reviews.",
  "private": true,
  "type": "commonjs",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/app.ts",
    "start": "node dist/app.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
