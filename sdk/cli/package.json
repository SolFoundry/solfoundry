    "dev": "ts-node --esm index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@solfoundry/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "solfoundry",
    "solana",
    "bounty",
