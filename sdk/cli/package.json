{
  "name": "@solfoundry/cli",
  "version": "0.1.0",
  "description": "Command-line interface for the SolFoundry bounty platform",
  "license": "MIT",
  "type": "module",
  "bin": {
    "solfoundry": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
