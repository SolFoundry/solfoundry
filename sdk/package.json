{
  "name": "@solfoundry/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for SolFoundry on-chain programs and REST APIs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./programs": {
      "import": "./dist/programs/index.js",
      "types": "./dist/programs/index.d.ts"
    }
  },
  "files": [
    "dist",
    "idl",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": ">=0.30.0",
    "@solana/web3.js": ">=1.90.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SolFoundry/solfoundry",
    "directory": "sdk"
  },
  "keywords": [
    "solana",
    "anchor",
    "solfoundry",
    "sdk",
    "typescript"
  ]
}
