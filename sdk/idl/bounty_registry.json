          { "name": "contributor", "type": { "option": "pubkey" } },
          { "name": "github_issue", "type": "string" },
          { "name": "github_pr", "type": "string" },
          { "name": "review_scores", "type": { "vec": "u16" } },
          { "name": "final_score", "type": "u16" },
          { "name": "pr_hash", "type": { "option": { "array": ["u8", 32] } } },
          { "name": "created_at", "type": "i64" },
          { "name": "updated_at", "type": "i64" },
          { "name": "completed_at", "type": { "option": "i64" } },
          { "name": "bump", "type": "u8" }
