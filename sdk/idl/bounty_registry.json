  "types": [
    {
      "name": "BountyRecord",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "bounty_id", "type": "u64" },
          { "name": "title", "type": "string" },
          { "name": "tier", "type": "u8" },
          { "name": "reward_amount", "type": "u64" },
          { "name": "status", "type": { "defined": { "name": "BountyStatus" } } },
