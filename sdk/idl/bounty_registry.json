        { "name": "system_program", "address": "11111111111111111111111111111111" }
      ],
      "args": [
        { "name": "bounty_id", "type": "u64" },
        { "name": "title", "type": "string" },
        { "name": "tier", "type": "u8" },
        { "name": "reward_amount", "type": "u64" },
        { "name": "github_issue", "type": "string" }
      ]
    },
    {
      "name": "update_status",
      "discriminator": [29, 252, 73, 11, 129, 187, 110, 151],
      "accounts": [
        { "name": "admin", "writable": true, "signer": true },
        { "name": "bounty_record", "writable": true }
      ],
      "args": [
        { "name": "new_status", "type": "u8" },
        { "name": "contributor", "type": { "option": "pubkey" } }
      ]
    },
    {
      "name": "record_completion",
      "discriminator": [205, 174, 39, 3, 98, 157, 62, 130],
      "accounts": [
        { "name": "admin", "writable": true, "signer": true },
        { "name": "bounty_record", "writable": true }
      ],
      "args": [
        { "name": "github_pr", "type": "string" },
        { "name": "review_scores", "type": { "vec": "u16" } },
        { "name": "final_score", "type": "u16" },
        { "name": "pr_hash", "type": { "array": ["u8", 32] } }
      ]
    },
    {
      "name": "close_bounty",
      "discriminator": [178, 54, 79, 142, 2, 18, 235, 148],
      "accounts": [
        { "name": "admin", "writable": true, "signer": true },
        { "name": "bounty_record", "writable": true }
      ],
      "args": []
    }
  ],
  "accounts": [
    { "name": "BountyRecord", "discriminator": [142, 49, 166, 150, 43, 197, 101, 42] }
