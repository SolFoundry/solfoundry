{
  "name": "solfoundry-bounty-browser",
  "displayName": "SolFoundry Bounty Browser",
  "description": "Browse, search, and submit claims for SolFoundry bounties directly from VS Code",
  "version": "0.1.0",
  "publisher": "solfoundry",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:solfoundryBountyExplorer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "solfoundry-bounty",
          "title": "SolFoundry Bounties",
          "icon": "$(trophy)"
        }
      ]
    },
    "views": {
      "solfoundry-bounty": [
        {
          "id": "solfoundryBountyExplorer",
          "name": "Bounties",
          "icon": "$(trophy)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "solfoundryBountyExplorer",
        "contents": "No bounties found.\n[Refresh Bounties](solfoundryBounty.refresh)"
      }
    ],
    "commands": [
      {
        "command": "solfoundryBounty.refresh",
        "title": "Refresh Bounties",
        "icon": "$(refresh)"
      },
      {
        "command": "solfoundryBounty.showDetail",
        "title": "Show Bounty Detail"
      },
      {
        "command": "solfoundryBounty.submitClaim",
        "title": "Submit Claim for Bounty"
      },
      {
        "command": "solfoundryBounty.openInBrowser",
        "title": "Open Bounty in Browser"
      },
      {
        "command": "solfoundryBounty.setApiUrl",
        "title": "Set SolFoundry API URL"
      },
      {
        "command": "solfoundryBounty.setAuthToken",
        "title": "Set SolFoundry Auth Token"
      },
      {
        "command": "solfoundryBounty.filterOpen",
        "title": "Show Open Bounties Only",
        "icon": "$(check)"
      },
      {
        "command": "solfoundryBounty.filterAll",
        "title": "Show All Bounties",
        "icon": "$(list-ordered)"
      },
      {
        "command": "solfoundryBounty.filterT1",
        "title": "Filter by Tier 1",
        "icon": "$(star-empty)"
      },
      {
        "command": "solfoundryBounty.filterT2",
        "title": "Filter by Tier 2",
        "icon": "$(star-empty)"
      },
      {
        "command": "solfoundryBounty.filterT3",
        "title": "Filter by Tier 3",
        "icon": "$(star-empty)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "solfoundryBounty.refresh",
          "when": "view == solfoundryBountyExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "solfoundryBounty.showDetail",
          "when": "view == solfoundryBountyExplorer && viewItem == bounty",
          "group": "inline"
        },
        {
          "command": "solfoundryBounty.openInBrowser",
          "when": "view == solfoundryBountyExplorer && viewItem == bounty",
          "group": "1_actions"
        },
        {
          "command": "solfoundryBounty.submitClaim",
          "when": "view == solfoundryBountyExplorer && viewItem == bounty",
          "group": "1_actions"
        }
      ]
    },
    "configuration": {
      "title": "SolFoundry Bounty Browser",
      "properties": {
        "solfoundryBounty.apiUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "Base URL for the SolFoundry API"
        },
        "solfoundryBounty.authToken": {
          "type": "string",
          "default": "",
          "description": "JWT auth token for authenticated requests (optional)"
        },
        "solfoundryBounty.defaultStatus": {
          "type": "string",
          "enum": [
            "open",
            "funded",
            "in_review",
            "completed",
            "all"
          ],
          "default": "open",
          "description": "Default status filter for bounty list"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "lint": "echo 'No lint configured'"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.3.3"
  },
  "license": "MIT"
}
