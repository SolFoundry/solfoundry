{
  "name": "solfoundry-bounty-creator",
  "version": "1.0.0",
  "description": "GitHub Action to automatically convert labeled issues into SolFoundry bounties",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts --license LICENSE --target es2022",
    "test": "tsx src/__tests__/main.test.ts",
    "lint": "eslint src/**/*.ts",
    "all": "npm run build && npm test"
  },
  "keywords": [
    "github-action",
    "solfoundry",
    "bounty",
    "solana",
    "fndry"
  ],
  "author": "OpenClaw-Auditor",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
