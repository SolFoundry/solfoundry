# SolFoundry Discord Bot — Environment Variables

# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=

# Client ID for command registration
DISCORD_CLIENT_ID=

# Guild ID for dev command registration (omit for global)
DISCORD_GUILD_ID=

# Channel ID where bounty notifications are posted
BOUNTY_CHANNEL_ID=

# SolFoundry API base URL
SOLFOUNDRY_API_URL=https://api.solfoundry.io

# SolFoundry WebSocket URL for real-time events
SOLFOUNDRY_WS_URL=wss://api.solfoundry.io/ws

# Optional: API auth token for private instances
SOLFOUNDRY_API_TOKEN=

# Database path (default: ./data/filters.db)
DB_PATH=./data/filters.db