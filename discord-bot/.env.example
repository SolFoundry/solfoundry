# SolFoundry Discord Bot Configuration
# Copy this file to .env and fill in the values

# Discord bot token (required)
DISCORD_BOT_TOKEN=your-bot-token-here

# Discord application/client ID (required for slash command registration)
DISCORD_CLIENT_ID=your-client-id-here

# Target Discord guild/server ID (optional, for guild-scoped commands)
DISCORD_GUILD_ID=

# Bounty notification channel ID (required)
BOUNTY_CHANNEL_ID=your-bounty-channel-id

# Announcements channel ID (optional, for general announcements)
ANNOUNCEMENTS_CHANNEL_ID=

# Leaderboard channel ID (optional, for periodic leaderboard posts)
LEADERBOARD_CHANNEL_ID=

# SolFoundry API base URL
SOLFOUNDRY_API_URL=https://api.solfoundry.io

# SolFoundry API auth token (for backend access)
SOLFOUNDRY_API_TOKEN=

# Bounty polling interval in seconds (default: 60)
BOUNTY_POLL_INTERVAL=60

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Environment: development, production (default: development)
NODE_ENV=development
